{
  "name": "peer-map",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "demo:clean": "node -e \"const fs=require('fs');['dist','test-results','playwright-report'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npm run build && npx cap run android",
    "cap:copy": "npm run build && npx cap copy android",
    "cap:apk": "node ./scripts/cap-apk.mjs",
    "cap:doctor": "npx cap doctor",
    "android:sdk:setup": "node ./scripts/android-sdk-setup.mjs",
    "demo:preflight": "node ./scripts/demo-preflight.mjs",
    "demo:report": "node ./scripts/demo-report.mjs",
    "demo:bundle": "node ./scripts/demo-bundle.mjs",
    "demo:archive": "node ./scripts/demo-archive.mjs",
    "demo:housekeep": "node ./scripts/demo-housekeep.mjs",
    "demo:status": "node ./scripts/demo-status.mjs",
    "demo:verify": "node ./scripts/demo-verify.mjs",
    "demo:export": "node ./scripts/demo-export.mjs",
    "demo:ready": "npm run demo:clean && node ./scripts/demo-ready.mjs",
    "demo:studio": "npm run demo:ready && npm run cap:open",
    "demo:crosscheck": "node ./scripts/demo-crosscheck.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "i18next": "^26.0.9",
    "leaflet": "^1.9.4",
    "mapbox-gl": "^3.23.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/leaflet": "^1.9.14",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.3.0",
    "@eslint/js": "^9.21.0",
    "typescript-eslint": "^8.24.1",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.1"
  }
}
