{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@location-emitter/packet": ["../../shared/packet/src/index.ts"],
      "@location-emitter/mesh": ["../../shared/mesh/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "vite.config.ts", "playwright.config.ts", "e2e/**/*.ts"]
}
