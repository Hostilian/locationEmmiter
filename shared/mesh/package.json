    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@location-emitter/packet": "file:../packet"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "fast-check": "^4.7.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.10",
    "typescript": "^6.0.3"
  }
