{
  "name": "location-emitter",
  "private": true,
  "workspaces": [
    "shared/packet",
    "shared/mesh"
  ],
  "scripts": {
    "build": "npm run build -w @location-emitter/packet && npm run build -w @location-emitter/mesh",
    "test": "npm run build -w @location-emitter/packet && npm run test -w @location-emitter/packet && npm run test -w @location-emitter/mesh && node --test tools/*.test.mjs",
    "verify:decode": "npm run build && node tools/verify-decode.mjs",
    "verify:peer-map": "npm --prefix web/peer-map run build",
    "demo:ready": "npm --prefix web/peer-map run demo:ready",
    "demo:studio": "npm --prefix web/peer-map run demo:studio",
    "demo:apk": "npm --prefix web/peer-map run cap:apk",
    "demo:preflight": "npm --prefix web/peer-map run demo:preflight",
    "demo:report": "npm --prefix web/peer-map run demo:report",
    "demo:bundle": "npm --prefix web/peer-map run demo:bundle",
    "demo:archive": "npm --prefix web/peer-map run demo:archive",
    "demo:housekeep": "npm --prefix web/peer-map run demo:housekeep",
    "demo:status": "npm --prefix web/peer-map run demo:status",
    "demo:verify": "npm --prefix web/peer-map run demo:verify",
    "demo:export": "npm --prefix web/peer-map run demo:export",
    "demo:crosscheck": "npm --prefix web/peer-map run demo:crosscheck",
    "decode-packet": "node tools/decode-packet.mjs",
    "decode-packet-all": "node tools/decode-packet.mjs --all-lines",
    "decode-packet-all-jsonl": "node tools/decode-packet.mjs --all-lines --jsonl",
    "encode-packet": "node tools/encode-packet.mjs",
    "airtime": "node tools/lora-airtime.mjs",
    "lint": "eslint shared web/peer-map/src",
    "lint:fix": "eslint shared web/peer-map/src --fix",
    "format": "prettier --write \"shared/**/*.ts\" \"web/peer-map/src/**/*.ts\" \"tools/*.{mjs,js}\"",
    "typecheck": "npm run typecheck --workspaces --if-present && npm --prefix web/peer-map run typecheck",
    "clean": "npm run clean --workspaces --if-present && npm --prefix web/peer-map run clean --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.5.2",
    "typescript-eslint": "^8.24.1"
  }
}
